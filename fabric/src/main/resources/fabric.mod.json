{
  "schemaVersion": 1,
  "id": "sableedit",
  "version": "${version}",
  "name": "SableEdit",
  "description": "${description}",
  "authors": [
    "${author}"
  ],
  "contact": {
    "homepage": "malaclord.github.io"
  },
  "license": "MIT",
  "icon": "assets/sableedit/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "hu.malaclord.sableedit.fabric.SableEditFabric"
    ],
    "client": [
